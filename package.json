{
  "name": "descusanjuan",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "prettier --check . && turbo run lint",
    "format": "prettier --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.0.1",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "typescript-eslint": "8.62.0"
  }
}
